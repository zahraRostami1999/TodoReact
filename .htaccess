# ---------------------------- general directives

RewriteEngine on

Options -Indexes
DirectoryIndex index.php index.html

# ---------------------------- remove file slash

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1

# ---------------------------- remove www

RewriteCond %{HTTP_HOST} ^www\.
RewriteCond %{HTTPS}s ^on(s)|off
RewriteCond http%1://%{HTTP_HOST} ^(https?://)(www\.)?(.+)$
RewriteRule ^ %1%3%{REQUEST_URI}

# ---------------------------- api routing

# for every request which starts with /api, serve api/index.php content
RewriteRule ^api/.*$ /api/index.php [L,QSA,NC]

# ---------------------------- block direct php requests

# WE DON'T USE PHP: for every request with .php postfix, return 404
RewriteCond %{THE_REQUEST} ^[^\?\.]+\.php
RewriteRule ^ - [R=404,L,QSA,NC]

# ---------------------------- allow react refresh

RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
